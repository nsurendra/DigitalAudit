{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/wizard",
      "dest": "/wizard.html"
    },
    {
      "src": "/single-page",
      "dest": "/single-page.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
